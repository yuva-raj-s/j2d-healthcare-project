{
    "name": "PL_J2D_HealthcareIngest",
    "properties": {
        "description": "J2D Healthcare – End-to-end weekly parameter-driven ingestion pipeline. Copies Hospital (MySQL), Device (Azure SQL), Pharma (PostgreSQL) to Raw layer, then triggers Raw → Silver → Gold Databricks notebooks.",
        "activities": [
            {
                "name": "Copy_Hospital_From_MySQL",
                "description": "Copy hospital_events table from Azure MySQL to ADLS rawlayer CSV",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "MySqlSource"
                    },
                    "sink": {
                        "type": "DelimitedTextSink",
                        "storeSettings": {
                            "type": "AzureBlobFSWriteSettings"
                        },
                        "formatSettings": {
                            "type": "DelimitedTextWriteSettings",
                            "quoteAllText": true,
                            "fileExtension": ".csv"
                        }
                    },
                    "enableStaging": false,
                    "translator": {
                        "type": "TabularTranslator",
                        "typeConversion": true,
                        "typeConversionSettings": {
                            "allowDataTruncation": true,
                            "treatBooleanAsNumber": false
                        }
                    }
                },
                "inputs": [
                    {
                        "referenceName": "DS_MySQL_HospitalEvents",
                        "type": "DatasetReference"
                    }
                ],
                "outputs": [
                    {
                        "referenceName": "DS_ADLS_Raw_Hospital",
                        "type": "DatasetReference"
                    }
                ]
            },
            {
                "name": "Copy_Device_From_AzureSQL",
                "description": "Copy device_events table from Azure SQL DB to ADLS rawlayer CSV",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "AzureSqlSource",
                        "queryTimeout": "02:00:00",
                        "partitionOption": "None"
                    },
                    "sink": {
                        "type": "DelimitedTextSink",
                        "storeSettings": {
                            "type": "AzureBlobFSWriteSettings"
                        },
                        "formatSettings": {
                            "type": "DelimitedTextWriteSettings",
                            "quoteAllText": true,
                            "fileExtension": ".csv"
                        }
                    },
                    "enableStaging": false
                },
                "inputs": [
                    {
                        "referenceName": "DS_AzureSQL_DeviceEvents",
                        "type": "DatasetReference"
                    }
                ],
                "outputs": [
                    {
                        "referenceName": "DS_ADLS_Raw_Device",
                        "type": "DatasetReference"
                    }
                ]
            },
            {
                "name": "Copy_Pharma_From_PostgreSQL",
                "description": "Copy pharma_events table from Azure PostgreSQL to ADLS rawlayer CSV",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "PostgreSqlV2Source"
                    },
                    "sink": {
                        "type": "DelimitedTextSink",
                        "storeSettings": {
                            "type": "AzureBlobFSWriteSettings"
                        },
                        "formatSettings": {
                            "type": "DelimitedTextWriteSettings",
                            "quoteAllText": true,
                            "fileExtension": ".csv"
                        }
                    },
                    "enableStaging": false
                },
                "inputs": [
                    {
                        "referenceName": "DS_PostgreSQL_PharmaEvents",
                        "type": "DatasetReference"
                    }
                ],
                "outputs": [
                    {
                        "referenceName": "DS_ADLS_Raw_Pharma",
                        "type": "DatasetReference"
                    }
                ]
            },
            {
                "name": "Run_Raw_NB",
                "description": "Trigger Databricks Raw_NB – CSV validation and Bronze Parquet write",
                "type": "DatabricksNotebook",
                "dependsOn": [
                    {
                        "activity": "Copy_Hospital_From_MySQL",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    },
                    {
                        "activity": "Copy_Device_From_AzureSQL",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    },
                    {
                        "activity": "Copy_Pharma_From_PostgreSQL",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 120
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Workspace/Users/avinashanu101@gmail.com/Raw_NB",
                    "baseParameters": {
                        "pipeline_name": {
                            "value": "@pipeline().Pipeline",
                            "type": "Expression"
                        },
                        "notebook_name": "raw_nb",
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        },
                        "source": "MySQL|AzureSQL|PostgreSQL",
                        "input_date": {
                            "value": "@pipeline().parameters.input_date",
                            "type": "Expression"
                        }
                    }
                },
                "linkedServiceName": {
                    "referenceName": "LS_AzureDatabricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "Run_Silver_NB",
                "description": "Trigger Databricks Silver_NB – Bronze to Silver Delta tables",
                "type": "DatabricksNotebook",
                "dependsOn": [
                    {
                        "activity": "Run_Raw_NB",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 120
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Workspace/Users/avinashanu101@gmail.com/Silver_NB",
                    "baseParameters": {
                        "pipeline_name": {
                            "value": "@pipeline().Pipeline",
                            "type": "Expression"
                        },
                        "notebook_name": "silver_nb",
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        },
                        "source": "MySQL|AzureSQL|PostgreSQL",
                        "input_date": {
                            "value": "@pipeline().parameters.input_date",
                            "type": "Expression"
                        }
                    }
                },
                "linkedServiceName": {
                    "referenceName": "LS_AzureDatabricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "Run_Gold_NB",
                "description": "Trigger Databricks Gold_NB – Silver to Gold Parquet in ADLS",
                "type": "DatabricksNotebook",
                "dependsOn": [
                    {
                        "activity": "Run_Silver_NB",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 120
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Workspace/Users/avinashanu101@gmail.com/Gold_NB",
                    "baseParameters": {
                        "pipeline_name": {
                            "value": "@pipeline().Pipeline",
                            "type": "Expression"
                        },
                        "notebook_name": "gold_nb",
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        },
                        "source": "MySQL|AzureSQL|PostgreSQL",
                        "input_date": {
                            "value": "@pipeline().parameters.input_date",
                            "type": "Expression"
                        }
                    }
                },
                "linkedServiceName": {
                    "referenceName": "LS_AzureDatabricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "OnFailure_Notify",
                "description": "Web activity to log pipeline failure to audit or alert team",
                "type": "WebActivity",
                "dependsOn": [
                    {
                        "activity": "Run_Raw_NB",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    },
                    {
                        "activity": "Run_Silver_NB",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    },
                    {
                        "activity": "Run_Gold_NB",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.00:10:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30
                },
                "userProperties": [],
                "typeProperties": {
                    "method": "POST",
                    "headers": {
                        "Content-Type": "application/json"
                    },
                    "url": "https://prod-xx.eastus.logic.azure.com/workflows/REPLACE_WITH_YOUR_LOGIC_APP_URL",
                    "body": {
                        "value": "@concat('{\"pipelineName\":\"', pipeline().Pipeline, '\",\"runId\":\"', pipeline().RunId, '\",\"status\":\"FAILED\"}')",
                        "type": "Expression"
                    }
                }
            }
        ],
        "parameters": {
            "input_date": {
                "type": "string",
                "defaultValue": "20260201"
            }
        },
        "folder": {
            "name": "J2D_Healthcare"
        },
        "annotations": [
            "j2d-healthcare",
            "medallion-architecture",
            "weekly-ingestion"
        ]
    }
}
